RAYFLOW_HTTP_ADDR=127.0.0.1:8787
RAYFLOW_DB_PATH=data/rayflow.db
RAYFLOW_MIGRATIONS_DIR=migrations
RAYFLOW_CONFIGS_DIR=configs
RAYFLOW_LOGS_DIR=logs
RAYFLOW_PRESETS_DIR=presets
RAYFLOW_AUTH_TOKEN=
RAYFLOW_DEFAULT_CORE=sing-box
RAYFLOW_LOCAL_PROXY_PORT=2080

# Runtime preferences are stored in SQLite after first launch.
# These env values are only initial/fallback values for local development.

# Configure absolute paths in local development.
RAYFLOW_SING_BOX_PATH=
RAYFLOW_XRAY_PATH=
RAYFLOW_ZAPRET_PATH=

VITE_RAYFLOW_API_URL=http://127.0.0.1:8787
VITE_RAYFLOW_AUTH_TOKEN=
